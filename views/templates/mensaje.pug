extends ../layout/index 

block contenido
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center.text-eed-600 Bienes
            span.font-normal.text-black Raíces
        h2.text-center.text-2xl.font-extrabold= pagina

        .bg-white.py-8.px-4.shadow-2xl.rounded-2xl.max-w-md.mx-auto.mt-10
            p.text-xl.font-bold.text-center.my-10= msg

            //- Cambiamos 'boton' por 'buttonVisibility' para que coincida con el controlador
            if buttonVisibility
                div.flex.justify-center.mt-5
                    //- Usamos las variables dinámicas para el enlace y el texto
                    a(href=buttonURL class="bg-red-600 hover:bg-red-800 text-white font-bold py-3 px-10 rounded-xl uppercase transition-all text-sm text-center inline-block")= buttonText