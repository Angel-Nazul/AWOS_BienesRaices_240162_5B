extends ../layout/index

block contenido
  .py-1
  h1.text-4xl.my-10.font-extrabold.text-center.text-red-600 Bienes
    span.font-normal.text-black Raíces
  h2.text-center.text-2xl.font-normal.text-black Por favor ingresa cuidadosamente tus datos

   if errores 
            .max-w-md.mx-auto.my-10 
                each error in errores 
                    p.bg-red-600.text-white.uppercase.text-xs.text-center.p-2.mb-1.font-bold= error.msg

  .mt-8.mx-auto.max-w-xl
    .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
      form.space-y-5(method="POST" action="/auth/registro" noValidate)
        input(type="hidden" name="_csrf" value=csrfToken)
        div.px-5
          label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="nombreUsuario") nombre completo:
          input#nombreUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400.bg-white.transition-shadow.duration-200(
            placeholder="Ej: Angel Nazul Gutiérrez Cruz"
            name="nombreUsuario"
            type="text"
            class="hover:inset-shadow-sm hover:shadow-[0_-4px_0_0_#ef4444] focus:inset-shadow-xl focus:inset-shado-300 focus:outline-none"
            value= usuario ? usuario.nombreUsuario: ''
          )

        div.px-5
          label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="emailUsuario") correo electrónico:
          input#emailUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400.bg-white.transition-shadow.duration-200(
            placeholder="Ej: usuario@dominio.com"
            name="emailUsuario"
            type="email"
            class="hover:inset-shadow-sm hover:shadow-[0_-4px_0_0_#ef4444] focus:inset-shadow-md focus:inset-shado-300/50 focus:outline-none"
            value= usuario ? usuario.emailUsuario: ''
          )

        div.px-5
          label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="paswordUsuario") contraseña:
          input#passwordUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400.bg-white.transition-shadow.duration-200(
            placeholder="Por lo menos 8 caracteres"
            name="passwordUsuario"
            type="password"
            class="hover:inset-shadow-sm hover:shadow-[0_-4px_0_0_#ef4444] focus:inset-shadow-md focus:inset-shado-300/50 focus:outline-none"
          )

        div.px-5
          label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="confirmacionUsuario") Confirmacion de contraseña:
          input#confirmacionUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400.bg-white.transition-shadow.duration-200(
            placeholder="Repite la contraseña anterior"
            name="confirmacionUsuario"
            type="password"
            class="hover:inset-shadow-sm hover:shadow-[0_-4px_0_0_#ef4444] focus:inset-shadow-md focus:inset-shado-300/50 focus:outline-none"
          )

        input(class="w-full bg-gray-300 text-red-600 hover:bg-red-600 hover:text-white font-bold py-3 cursor-pointer rounded-4xl shadow-lg uppercase transition-all.duration-200" type="submit" value="Registrar Usuario")

  .mt-6.space-y-3
  p.text-center.text-gray-500.text-sm O regístrate con
  .flex.flex-col.sm: flex-row.gap-3
    a.flex-1.flex.items-center.justify-center.gap-2.bg-black.hover: bg-gray-800.text-white.font-bold.py-2.px-4.rounded-xl.transition-all.duration-200.hover: scale-105.hover: shadow-lg.focus: outline-none(href="#")
      svg.w-5.h-5(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor")
        path(d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.879v-6.99h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.99C18.343 21.128 22 16.991 22 12z")
      span Facebook
    a.flex-1.flex.items-center.justify-center.gap-2.bg-white.border.border-gray-300.hover: bg-gray-100.text-gray-700.font-bold.py-2.px-4.rounded-xl.transition-all.duration-200.hover: scale-105.hover: shadow-lg.focus: outline-none(href="#")
      svg.w-5.h-5(viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg")
        path(fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z")
        path(fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z")
        path(fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z")
        path(fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z")
      span Google

    div.flex.items-center.justify-between.pt-3
        a.text-gray-500.text-sm.hover-decoration-red-600.hover-underline.transition.decoration-2(href="/auth/login") ¿Ya tienes cuenta? Inicia Sesión
          
        a.text-gray-500.text-sm.hover-decoration-red-600.hover-underline.transition.decoration-2(href="/auth/recuperarPassword") ¿Olvidaste tu contraseña? Recuperarla